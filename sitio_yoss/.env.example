# Puerto en el que correrá el servidor web (por defecto 3000)
PORT=3000

# Cadena de conexión a MongoDB. Cambiar si la base de datos está alojada externamente (ej. MongoDB Atlas)
MONGODB_URI=mongodb://localhost:27017/yoss

# Secreto utilizado para firmar los JSON Web Tokens.
# ¡IMPORTANTE! Cambiar a un valor largo, aleatorio y seguro para producción.
JWT_SECRET=cambia_este_secreto_en_produccion

# Tiempo de expiración de la sesión (ej. '1h' para una hora, '7d' para 7 días)
JWT_EXPIRES_IN=7d

# Entorno de Node.js ('development' para desarrollo local, 'production' para el despliegue)
# En producción, se activarán ciertas optimizaciones y se ocultarán trazas de errores.
NODE_ENV=development
